user www-data;
worker_processes auto;
worker_rlimit_nofile 4096;
pid /run/nginx.pid;

events {
    worker_connections 1024;
    multi_accept on;
}

http {
    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    types_hash_max_size 2048;
    server_tokens off;

    include /etc/nginx/mime.types;
    include /etc/nginx/fastcgi.conf;
    default_type application/octet-stream;

    client_body_timeout 10s;
    client_header_timeout 10s;
    send_timeout 10s;
    keepalive_timeout 15s;
    client_max_body_size 2m;

    limit_req_zone $binary_remote_addr zone=req_general:10m rate=10r/s;
    limit_req_zone $binary_remote_addr zone=req_cgi:10m rate=5r/s;
    limit_conn_zone $binary_remote_addr zone=conn_general:10m;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    access_log /var/log/nginx/access.log;
    error_log /var/log/nginx/error.log;

    gzip on;

    server {
        listen 80 default_server;
        listen [::]:80 default_server;
        server_name _;
        return 444;
    }

    server {
        listen 80;
        listen [::]:80;
        server_name {{ domain }};

        root /var/www/{{ domain }};

        limit_req zone=req_general burst=20 nodelay;
        limit_conn conn_general 20;

        add_header X-Content-Type-Options nosniff always;
        add_header X-Frame-Options DENY always;
        add_header Referrer-Policy strict-origin-when-cross-origin always;

        location ~ (^|/)\. {
            deny all;
            return 404;
        }
        location ~ (^|/)_ {
            deny all;
            return 404;
        }

        location ~ ~$ {
            deny all;
        }

        location = / {
            try_files /default.ct /main.ct =404;
        }

        location ~ \.ct$ {
            try_files $uri =404;
            default_type text/html;
            limit_req zone=req_cgi burst=10 nodelay;
            gzip off;
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            include /etc/nginx/fastcgi_params;
            fastcgi_param LANG en_US.UTF-8;
            fastcgi_param LC_ALL en_US.UTF-8;
            fastcgi_param SCRIPT_FILENAME {{ ct2html_cgi_path }};
            fastcgi_param CT_FILE $document_root$uri;
            fastcgi_read_timeout 10s;
            fastcgi_send_timeout 10s;
        }

        location / {
            return 404;
        }
    }
}